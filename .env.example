# ---- core ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173

# ---- database ----
DATABASE_URL=postgres://mfa:mfa@localhost:5432/mfa

# ---- free providers (no key required) ----
# Denver Open Data + Census need no keys.
# Census API works without a key but is aggressively rate-limited.
# Register a free key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS (Treasury/CPI/local unemployment) works without a key but is rate-limited
# (25/day anonymous -> 500/day registered). Register at https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# FBI Crime Data Explorer (crime stats used in Buy Box scoring) — needs a free
# api.data.gov key. Register at https://api.data.gov/signup/
FBI_API_KEY=

# HUD Fair Market Rent API — required for the HUD FMR provider (shows
# needs_credentials until set, nothing else depends on it). Register at
# https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=

# ---- free with key ----
GOOGLE_MAPS_API_KEY=
# Same key is exposed to the browser via Vite (must be prefixed VITE_).
# Restrict this key to HTTP referrers in Google Cloud Console before deploying publicly.
VITE_GOOGLE_MAPS_API_KEY=

# ---- paid (leave blank to show "needs_credentials" in UI) ----
ATTOM_API_KEY=
RENTCAST_API_KEY=

# ---- apps/crm: Firebase (Auth + Firestore for the SmartInvestorCRM dashboard) ----
# Project: https://console.firebase.google.com/project/smartinvestorcrm
# These are client config values, not secrets — safe to commit/embed in the
# built bundle. Get the appId from Firebase Console -> Project Settings ->
# General -> Your apps -> Web app (apiKey/authDomain/projectId/storageBucket/
# messagingSenderId below already match the live smartinvestorcrm.com deploy;
# only appId is missing since it wasn't visible in the scraped bundle).
VITE_FIREBASE_API_KEY=AIzaSyBIcIco4I2TJi8XrUcgRVM8DxJHCfp3ZXY
VITE_FIREBASE_AUTH_DOMAIN=smartinvestorcrm.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=smartinvestorcrm
VITE_FIREBASE_STORAGE_BUCKET=smartinvestorcrm.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=576601480079
VITE_FIREBASE_APP_ID=
# Set to "true" to run apps/crm against the local Firebase Auth/Firestore
# emulators instead of the real smartinvestorcrm project (see
# `firebase emulators:start --only auth,firestore`).
VITE_USE_FIREBASE_EMULATOR=
