# ---- core ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173

# ---- database ----
DATABASE_URL=postgres://mfa:mfa@localhost:5432/mfa

# ---- free providers (no key required) ----
# Denver Open Data + Census + HUD need no keys.
# Census API works without a key but is aggressively rate-limited.
# Register a free key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ---- free with key ----
GOOGLE_MAPS_API_KEY=
# Same key is exposed to the browser via Vite (must be prefixed VITE_).
# Restrict this key to HTTP referrers in Google Cloud Console before deploying publicly.
VITE_GOOGLE_MAPS_API_KEY=

# ---- paid (leave blank to show "needs_credentials" in UI) ----
ATTOM_API_KEY=
RENTCAST_API_KEY=
