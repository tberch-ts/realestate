rules_version = '2';

// SmartInvestorCRM data rules. Firebase Hosting was retired in favor of
// GitHub Pages (see project-docs/DEPLOY_FLY.md) — this project is kept
// solely for Auth + Firestore. Deploy with:
//   firebase deploy --only firestore:rules --project smartinvestorcrm
//
// Matches the real production schema (verified directly against the
// deployed rules/indexes on the live "smartinvestorcrm" project, not
// guessed): docs carry `ownerId` (not `userId`), and deals/LOIs/capital
// raises support team-sharing via a `members` array — the owner can
// delete, owner-or-member can read/update.

function isSignedIn() {
  return request.auth != null;
}

function isOwner(resource) {
  return request.auth.uid == resource.data.ownerId;
}

function isMember(resource) {
  return request.auth.uid in resource.data.get('members', []);
}

function isAdmin() {
  return isSignedIn() && request.auth.token.admin == true;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's own profile/plan doc, keyed by uid. plan/planStatus/
    // stripeCustomerId/stripeSubscriptionId are server-authoritative — only
    // the Stripe webhook (via the Admin SDK, which bypasses these rules
    // entirely) may set them, so a client can never grant itself a paid plan.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.plan == 'free'
        && !('stripeCustomerId' in request.resource.data)
        && !('stripeSubscriptionId' in request.resource.data);

      allow update: if isSignedIn() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['plan', 'planStatus', 'stripeCustomerId', 'stripeSubscriptionId']);
    }

    match /deals/{dealId} {
      allow read, update: if isSignedIn() && (isOwner(resource) || isMember(resource));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isSignedIn() && isOwner(resource);
    }

    match /contacts/{contactId} {
      allow read, write: if isSignedIn() && isOwner(resource);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;

      // Interaction timeline — our own addition (not in the original
      // production schema, but a reasonable enhancement). ownerId is
      // denormalized onto each interaction doc so ownership can be checked
      // directly without a get() lookup on the parent contact.
      match /interactions/{interactionId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      }
    }

    match /lois/{loiId} {
      allow read, update: if isSignedIn() && (isOwner(resource) || isMember(resource));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isSignedIn() && isOwner(resource);
    }

    match /capital_raises/{raiseId} {
      allow read, update: if isSignedIn() && (isOwner(resource) || isMember(resource));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isSignedIn() && isOwner(resource);
    }

    // Shared reference data (e.g. MSA-level market signals) — readable by
    // any signed-in user, writable only via admin custom claim (backend/
    // Cloud Function use, not client writes).
    match /market_signals/{msaSlug} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Default deny — anything not explicitly matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
