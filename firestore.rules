rules_version = '2';

// SmartInvestorCRM data rules. Firebase Hosting was retired in favor of
// GitHub Pages (see project-docs/DEPLOY_FLY.md) — this project is kept
// solely for Auth + Firestore. Deploy with:
//   firebase deploy --only firestore:rules --project smartinvestorcrm

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's own profile/plan doc, keyed by uid.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Per-user CRM records — every doc must carry a userId field set to the
    // creator's uid at write time; ownership never changes after creation.
    match /deals/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /contacts/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);

      // Interaction timeline — userId is denormalized onto each interaction
      // doc (not just inherited from the parent contact) so ownership can be
      // checked directly without a get() lookup.
      match /interactions/{interactionId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if isOwner(request.resource.data.userId);
      }
    }

    match /lois/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /capital_raises/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // Default deny — anything not explicitly matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
